{
  "name": "invoice-platform",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22 <23",
    "pnpm": "11.9.0"
  },
  "volta": {
    "node": "22.23.1",
    "pnpm": "11.9.0"
  },
  "scripts": {
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "pnpm -r --if-present lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "build": "pnpm --filter @invoice/domain --filter @invoice/invoice-engine --filter @invoice/invoice-domain --filter @invoice/validation --filter @invoice/api-client --filter @invoice/ui --filter @invoice/web build",
    "web:dev": "pnpm --filter @invoice/web dev",
    "web:build": "pnpm --filter @invoice/web build",
    "mobile:start": "pnpm --filter @invoice/mobile start",
    "mobile:android": "pnpm --filter @invoice/mobile android"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "latest",
    "eslint": "10.5.0",
    "eslint-config-prettier": "latest",
    "eslint-plugin-react": "latest",
    "eslint-plugin-react-hooks": "latest",
    "globals": "latest",
    "prettier": "3.8.4",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "typescript-eslint": "latest",
    "vite": "8.1.0",
    "vitest": "4.1.9"
  }
}
